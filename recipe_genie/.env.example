# --- Supabase (client + server) ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
SUPABASE_PROJECT_ID="your-project-id"
# Server-only: bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Same values, exposed to the browser at build time by Vite:
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# --- AI provider (any OpenAI-compatible endpoint) ---
# Default below is Google Gemini's free tier. Key from aistudio.google.com.
AI_API_KEY="your-google-ai-studio-key"
AI_GATEWAY_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
AI_MODEL="gemini-2.5-flash"

# --- Jina Reader (recipe + price scraping) ---
# Optional: works without a key (throttled). Key from jina.ai for higher limits.
JINA_API_KEY="your-jina-key"
